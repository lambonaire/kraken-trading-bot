def private_request(method, endpoint, data=None):

    if data is None:
        data = {}

    nonce = str(int(time.time() * 1000))

    postdata = urlencode(data or {})
    print("DEBUG POSTDATA:", postdata)
    print("DEBUG NONCE:", nonce)
    print("DEBUG URL_PATH:", url_path)

    url_path = endpoint

    signature = generate_signature(method, url_path, postdata, nonce)
    print("DEBUG SIGNATURE:", signature)

    headers = {
        "APIKey": API_KEY,
        "Authent": signature,
        "Nonce": nonce
    }

    url = BASE_URL + endpoint

    try:
        if method == "GET":
            response = requests.get(url, headers=headers, params=data, timeout=10)
        else:
            response = requests.post(url, headers=headers, data=postdata, timeout=10)

        return response.json()

    except Exception as e:
        print(f"[ERROR private_request] {e}")
        return None



